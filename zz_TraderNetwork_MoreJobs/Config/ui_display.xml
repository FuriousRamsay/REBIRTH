	<append xpath="/ui_display_info/item_display" >		

		<item_display_info display_type="FuriousRamsayMechanicalAlly" display_group="groupMelee">
			<display_entry name="MaxDamage" title_key="statMaxDamage"/>
			<display_entry name="LightOpacity" title_key="statEntityDamage"/>
		</item_display_info>

		<item_display_info display_type="FuriousRamsayExplosiveMechanicalAlly" display_group="groupMelee">
