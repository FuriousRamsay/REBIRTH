<configs>

	<insertBefore xpath="/entity_classes/entity_class[@name='zombieTemplateMale']">
	
		<entity_class name="FuriousRamsayMeleeTemplate"> 
			<property name="Class" value="EntityAliveSDX, SCore" /> 
			<property name="SleeperInstantAwake" value="true" /> <!-- needed to make sure NPCs fully initialized on spawning in all sleeper volumes  -->
			<property name="EntityType" value="Player"/>
			<property name="Tags" value="entity,male,npc,melee"/> <!-- entity/sex/type/role/attacktype/name: Entity is required for code filtering, sex for sound filtering, type/role and Atype for buff filtering.  These DO NOT Extend! -->
			<property name="Mesh" value="#@modfolder:Resources/XythNPCs.unity3d?NurseNancy_X"/>
			<property name="AvatarController" value="AvatarZombie01Controller"/>
			<property name="HideInSpawnMenu" value="true"/> <!-- A19  -->
			<property name="ModelType" value="Standard"/>
			<property name="HasRagdoll" value="true"/>
			<property name="Prefab" value="NPC"/>
			<property name="Parent" value="Players"/>
			<property name="Mass" value="120"/>
			<property name="Weight" value="80"/>			
			<property name="PhysicsBody" value="mixamoConvertedStandard"/>
			<property name="MapIcon" value="ui_game_symbol_enemy_dot" />  
			<property name="CompassIcon" value="ui_game_symbol_enemy_dot" />  <!-- comment out these lines if you dont want to see the NPC name and location on map -->
			<property name="CompassUpIcon" value="ui_game_symbol_enemy_dot_up" />
			<property name="CompassDownIcon" value="ui_game_symbol_enemy_dot_down" />
			<property name="TrackerIcon" value="ui_game_symbol_run"/>		
			<property name="AINoiseSeekDist" value="30"/>	
			<property name="AIPathCostScale" value="1, 1"/>
			<property name="LookAtAngle" value="60"/> 
			<property name="AttackTimeoutDay" value="0.025"/>  <!-- 0.05 * 20f = 1 seconds between attack -->
            <property name="AttackTimeoutNight" value="0.025"/>
			<property name="RightHandJointName" value="RightWeapon" />  <!-- I put melee weapons and pistol type ranged weapons on this child object -->
			<property class="FallLandBehavior">
				<property name="1None" data="anim=None;height=0,1;weight=0.4"/>
				<property name="1Land" data="anim=Land;height=0,1;weight=0.4"/>
				<property name="1LandLow" data="anim=LandLow;height=0,1;weight=0.15"/>
				<property name="1Stumble" data="anim=Stumble;height=0,1;weight=0.05"/>
				<property name="LowLand" data="anim=LandLow;height=1,3;weight=0.7"/>
				<property name="LowStumble" data="anim=Stumble;height=1,3;weight=0.3"/>
				<property name="MidStumble" data="anim=Stumble;height=3,5;weight=0.3"/>
				<property name="MidStumbleAndRage" data="anim=Stumble;height=3,5;weight=0.3;ragePer=0.5,1.5;rageTime=1.0,2.0"/>
				<property name="MidLandHard" data="anim=LandHard;height=3,5;weight=0.3"/>
				<property name="MidLandHardAndRage" data="anim=LandHard;height=3,5;weight=0.3;ragePer=0.5,1.5;rageTime=1.0,2.0"/>
				<property name="Ragdoll" data="anim=Ragdoll;height=3;weight=0.4"/>
			</property>
			<property class="DestroyBlockBehavior">
				<property name="None" data="weight=0.0"/>
				<property name="Stumble" data="weight=0.2"/>
				<property name="Ragdoll" data="weight=0.2"/>
			</property>
			<property name="SwimSpeed" value="1.3"/>
			<property name="SwimStrokeRate" value="1.1,1.5"/>
			<property name="NavObject" value="clear_sleeper" />
			<property name="WalkType" value="7"/>
			<property name="SoundHurtSmall" value="Player_Male/player1painsm"/>
			<property name="SoundStamina" value="Player_Male/player1stamina"/>
			<property name="SoundDrownPain" value="Player_Male/player1drownpain"/>
			<property name="SoundWaterSurface" value="Player_Male/player1drownsurface"/>
			<property name="SoundDrownDeath" value="Player_Male/player1drowndeath"/>
			<property name="SoundJump" value="Player_Male/player1Jump"/>
			<property name="SoundLandSoft" value="Player_Male/player1LandSoft"/>
			<property name="SoundLandHard" value="Player_Male/player1LandHard"/>
			<property name="SoundPlayerLandThump" value="PlayerLandThump"/>
			<property name="SoundSleeperSense" value="sleepersense"/>
			<property name="SoundSleeperBackToSleep" value="sleeperbacktosleep"/>
			<property name="SoundAlertTime" value="25.0"/>
			<property name="SoundRandomTime" value="200.0"/>
			<property name="RootMotion" value="true"/>
			<property name="HasDeathAnim" value="true"/>
			<property name="ParticleOnDeath" value="blood_death"/>
			<property name="SurfaceCategory" value="organic"/> 
			<property name="DismemberMultiplierHead" value="1"/>
			<property name="DismemberMultiplierArms" value="0"/><!-- 1 when fixed  -->
			<property name="DismemberMultiplierLegs" value="0"/><!-- 1 when fixed  -->
			<property name="LegCrippleScale" value="0"/> <!-- 1 when fixed  -->
			<property name="LegCrawlerThreshold" value="0"/> <!-- 1 when fixed  -->
			<property name="KnockdownProneDamageThreshold" value="0.4"/>
			<property name="KnockdownProneStunDuration" value="0.5,0.5"/>
			<property name="KnockdownProneRefillRate" value="0.045,0.045"/>
			<property name="KnockdownKneelDamageThreshold" value="0.4"/>
			<property name="KnockdownKneelStunDuration" value="0.5,0.5"/>
			<property name="KnockdownKneelRefillRate" value="0.045,0.045"/>
			<property name="LegsExplosionDamageMultiplier" value="0"/><!-- 1 when fixed  -->
			<property name="ArmsExplosionDamageMultiplier" value="0"/><!-- 1 when fixed  -->
			<property name="HeadExplosionDamageMultiplier" value="1"/>
			<property name="ChestExplosionDamageMultiplier" value="1"/>
			<property name="PainResistPerHit" value=".6"/> <!-- Added when hit. Caps at 3. Decay .2 per second. At 1 movement is not slowed by pain -->
			<property name="MaxViewAngle" value="180"/> 
			<property name="SightRange" value="60"/>
			<property name="SightLightThreshold" value="-2,150"/> 
			<property name="SleeperWakeupSightDetectionMin" value="-40,5"/> 
			<property name="SleeperWakeupSightDetectionMax" value="340,480"/> 
			<property name="SleeperSenseSightDetectionMin" value="-10,0"/> 
			<property name="SleeperSenseSightDetectionMax" value="200,300"/>
			<property name="SleeperNoiseSenseThreshold" value="3,8"/> 
			<property name="SleeperNoiseWakeThreshold" value="9,12"/>
			<property name="SleeperSmellSenseThreshold" value="20,50"/> 
			<property name="SoundSleeperSenseChance" value=".5"/> 
			<property name="SleeperSmellWakeThreshold" value="40,100"/>
			<property name="NoiseAlertThreshold" value="30"/> 
			<property name="SmellAlertThreshold" value="40"/> 
			<property name="MaxTurnSpeed" value="250"/>
			<property name="SwimSpeed" value="1"/>
			<property name="SwimStrokeRate" value="1,1.5"/>
			<property name="CanClimbLadders" value="true"/>
			<property name="CanClimbVertical" value="false"/>
			<property name="JumpMaxDistance" value="2.8, 3.9"/> 
			<property name="Immunity" value="sickness;disease;wellness"/> 
			<property name="ExperienceGain" value="600"/> 
			<property name="LootDropProb" value="0.0"/> 
			<property name="LootDropEntityClass" value="EntityLootContainerBandit"/>
			<property name="Names" value="" />
			<property name="Titles" value="" />
			<property name="Beds" value="mattressFlat" />
			 <!-- This is the block it'll call home -->
			<property name="HomeBlocks" value="cntNPCHomeBlock"/>
			<property name="HireCurrency" value="casinoCoin" />
			<property name="HireCost" value="1000" />
			<property name="TimeStayAfterDeath" value="5"/>
			<property name="DeadBodyHitPoints" value="1000"/>
			<effect_group name="Base Effects">
				<passive_effect name="DistractionResistance" operation="base_set" value="0,0"/>
				<passive_effect name="HealthMax" operation="base_set" value="300"/>
				<passive_effect name="HealthMax" operation="perc_set" value="1"/>
				<passive_effect name="StaminaMax" operation="base_set" value="2000"/>
				<passive_effect name="PhysicalDamageResist" operation="base_set" value="10" />
				<passive_effect name="BuffResistance" operation="base_set" value="5" tags="buffBurningEnvironment,buffFatiguedTrigger,buffLaceration,buffInfectionCatch,buffAbrasionCatch,buffInjuryStunned01CHTrigger,buffInjuryBleedingTwo,buffInjuryBleedingBarbedWire"/> 
				<passive_effect name="BuffResistance" operation="base_set" value="1" tags="buffInjuryBleeding,buffInjuryBleedingZombie,buffLegSprained,buffLegBroken,buffArmSprained,buffPlayerFallingDamage,buffArmSprainedCHTrigger,buffLegSprainedCHTrigger"/>
				<passive_effect name="LandMineImmunity" operation="base_set" value="1"/> <!--  SCore add  -->
			</effect_group>	
			<!--<effect_group name="IsNPC"> 
				<triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="IsHuman"/> 
				<triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="buffNPCStatusCheck"/> 
				<triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="buffNPCStatusCheck"/>
				<triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="NPCHit"/> 
			</effect_group>	-->
			<property name="RotateToGround" value="false"/>	
			<property name="PushFactor" value="1"/>	
			<property name="DanceType" value="1" />
			<property name="MoveSpeed" value="0.5"/> 
			<property name="MoveSpeedAggro" value="2.0, 2.0"/> 
			<property name="MoveSpeedPanic" value="2.5"/>
			<property name="MoveSpeedRand" value="-.2, .25"/> 
			<effect_group>
				<passive_effect name="WalkSpeed" operation="base_set" value=".5"/>
				<passive_effect name="RunSpeed" operation="base_set" value="1.0"/> 
				<passive_effect name="HealthChangeOT" operation="base_set" value="0.1"/>
				<passive_effect name="DamageModifier" operation="perc_set" value="1"/>
				<passive_effect name="DamageModifier" operation="perc_add" value="1" tags="head"/>
				<passive_effect name="DismemberChance" operation="base_set" value=".05"/> 
				<passive_effect name="WaterMax" operation="base_set" value="100"/> 
				<passive_effect name="CrouchSpeed" operation="base_set" value=".3"/> 
				<passive_effect name="WalkSpeed" operation="base_set" value="0.35" tags="swimming"/>
				<passive_effect name="RunSpeed" operation="base_set" value="0.35" tags="swimming"/>
				<passive_effect name="Mobility" operation="base_set" value="1"/> 
				<passive_effect name="JumpStrength" operation="base_set" value="0.16"/> 
			</effect_group>
			<effect_group>
				<passive_effect name="SpreadMultiplierAiming" operation="base_set" value="1"/>
				<passive_effect name="SpreadMultiplierCrouching" operation="base_set" value="1"/>
				<passive_effect name="SpreadMultiplierHip" operation="base_set" value="1"/>
				<passive_effect name="SpreadMultiplierWalking" operation="base_set" value="1"/>
				<passive_effect name="SpreadMultiplierRunning" operation="base_set" value="1.05"/>
				<passive_effect name="SpreadMultiplierIdle" operation="base_set" value="1"/>
				<passive_effect name="DegradationPerUse" operation="base_set" value="0"/>
				<passive_effect name="IncrementalSpreadMultiplier" operation="base_set" value="1"/>

				<passive_effect name="CraftingTier" operation="base_set" value="1"/>
				<passive_effect name="CarryCapacity" operation="base_set" value="27"/>
				<passive_effect name="BagSize" operation="base_set" value="45"/> 
				<passive_effect name="ProjectileStickChance" operation="base_set" value=".5"/>
				<passive_effect name="ProjectileStickChance" operation="perc_add" value="-2" tags="glass"/> 
			</effect_group> 
							
			<property name="AIPackages" value="NPCBasicNoChat, NPCMeleeBasic"/>  
			<property name="IsEnemyEntity" value="false"/> 
			<property name="Faction" value="whiteriver"/>
			
		</entity_class>	

		<entity_class name="FuriousRamsayZombieTemplate" extends="FuriousRamsayMeleeTemplate">
			<property name="HideInSpawnMenu" value="true"/>
			<property name="Tags" value="entity,zombie,walker"/>
			<property name="Faction" value="undead"/>
			<property name="WalkType" value="7"/>			
			<property name="Names" value="Template" />
			<!--<property name="HandItem" value="meleeNPCEmptyHand"/> 
			<property name="ItemsOnEnterGame.GameModeSurvival" value="meleeNPCEmptyHand"/>
			<property name="ItemsOnEnterGame.GameModeSurvivalSP" value="meleeNPCEmptyHand"/>
			<property name="ItemsOnEnterGame.GameModeSurvivalMP" value="meleeNPCEmptyHand"/> 
			<property name="HireCurrency" value="casinoCoin" />
			<property name="HireCost" value="750" />
			<property name="ExperienceGain" value="600"/> 
			<effect_group name="WeaponType"> 
				<triggered_effect trigger="onSelfFirstSpawn" action="AddBuff" target="self" buff="EmptyHandUser"/>
			</effect_group>-->
			<property name="HandItem" value="meleeHandZombie01"/>
			<property name="HandItemCrawler" value="meleeHandZombie02"/> <!-- meleeHandZombie02 is referenced in code but can be overridden -->
		</entity_class>		

	</insertBefore>
	
	<append xpath="/entity_classes/entity_class[@name='zombieTemplateMale']">
		<property name="Class" value="EntityAliveSDX, SCore" /> 
		<property name="AIPackages" value="NPCBasicNoChat2, NPCMeleeBasic"/>
	</append>
	
	<!--<setattribute xpath="/entity_classes/entity_class[@name='zombieBoe']" name="extends">FuriousRamsayZombieTemplate</setattribute>
	<setattribute xpath="/entity_classes/entity_class[@name='zombieBiker']" name="extends">FuriousRamsayZombieTemplate</setattribute>-->

	<append xpath="/entity_classes/entity_class[@name='zombieBoe']">
		<property name="Faction" value="whiteriver" />
	</append>

</configs>