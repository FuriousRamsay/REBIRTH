<Config>

	<append xpath="//item_display">

		<item_display_info display_type="FuriousRamsayAura" display_group="FuriousRamsayAuras">
			<display_entry name="dAuraRange" title_key="FuriousRamsayStatAuraRange"/>
		</item_display_info>

		<item_display_info display_type="FuriousRamsayThrowingKnife" display_group="groupMelee">
			<display_entry name="EntityDamage" title_key="FuriousRamsayStatEntityDamageThrown" tags="perkMiner69r,perkSalvageOperations,perkElectrocutioner,perkJavelinMaster,perkPummelPete,perkSkullCrusher,perkDeepCuts,perkBrawler,admin"/>
			<display_entry name="dEntityDamageSneak" title_key="statEntityDamageSneak" display_type="Percent" display_leading_plus="true"/>
			<display_entry name="BlockDamage" title_key="statBlockDamage" tags="perkMiner69r,perkSalvageOperations,perkElectrocutioner,perkJavelinMaster,perkPummelPete,perkSkullCrusher,perkDeepCuts,perkBrawler,admin"/>
			<display_entry name="StaminaLoss" title_key="statStaminaLoss" negative_preferred="true"/>
		</item_display_info>

		<item_display_info display_type="FuriousRamsayFoodWaterDysentery" display_group="groupConsumables">
			<display_entry name="$foodAmountAdd" title_key="statFoodAmount" />
			<display_entry name="foodHealthAmount" title_key="statHealthAmount" />
			<display_entry name="$waterAmountAdd" title_key="statWaterAmount" />
			<display_entry name=".foodStaminaBonusAdd" title_key="statFoodStaminaBonus" />
			<display_entry name="dDysenteryRisk" title_key="statDysenteryRisk" display_type="Percent" negative_preferred="true" />
		</item_display_info>

		<item_display_info display_type="FuriousRamsayFoodDysentery" display_group="groupConsumables">
			<display_entry name="$foodAmountAdd" title_key="statFoodAmount" />
			<display_entry name="foodHealthAmount" title_key="statHealthAmount" />
			<display_entry name=".foodStaminaBonusAdd" title_key="statFoodStaminaBonus" />
			<display_entry name="dDysenteryRisk" title_key="statDysenteryRisk" display_type="Percent" negative_preferred="true" />
		</item_display_info>

	</append>

